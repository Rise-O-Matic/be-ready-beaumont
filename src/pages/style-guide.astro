---
import Proposal from '../layouts/Proposal.astro';
import { base } from '../utils/base';

const colors = [
  { name: 'Dark', var: '--color-brand-dark', hex: '#0c1420', usage: 'Page backgrounds, hero sections' },
  { name: 'Navy', var: '--color-brand-navy', hex: '#141f33', usage: 'Primary text on light, section backgrounds' },
  { name: 'Steel', var: '--color-brand-steel', hex: '#1e2d45', usage: 'Card backgrounds on dark, subtle containers' },
  { name: 'Slate', var: '--color-brand-slate', hex: '#3a4a5c', usage: 'Body text, secondary headings' },
  { name: 'Muted', var: '--color-brand-muted', hex: '#7a8a9e', usage: 'Tertiary text, captions' },
  { name: 'Light', var: '--color-brand-light', hex: '#f0ede8', usage: 'Card backgrounds on cream, subtle fills' },
  { name: 'Cream', var: '--color-brand-cream', hex: '#faf8f4', usage: 'Page background (light sections)' },
  { name: 'Copper', var: '--color-brand-copper', hex: '#d4753e', usage: 'Primary accent — CTAs, links, highlights' },
  { name: 'Amber', var: '--color-brand-amber', hex: '#e8a84c', usage: 'Secondary warm accent, award badges' },
  { name: 'Teal', var: '--color-brand-teal', hex: '#2dd4a8', usage: 'Tertiary accent — partners, success states' },
];
---

<Proposal title="Style Guide" current="style-guide">
  <!-- Hero -->
  <section class="relative bg-brand-dark text-white py-20 md:py-28 overflow-hidden grain">
    <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-brand-copper/5 rounded-full blur-[120px]"></div>
    <div class="relative max-w-[900px] mx-auto px-5 sm:px-8">
      <p class="reveal text-[13px] font-semibold uppercase tracking-[0.2em] text-brand-copper mb-4">Step 3 of 5</p>
      <h1 class="reveal font-[Schibsted_Grotesk] text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.05]" style="animation-delay: 100ms">
        The visual<br />
        <span class="text-brand-copper">language.</span>
      </h1>
      <p class="reveal text-lg md:text-xl text-white/50 mt-6 max-w-xl leading-relaxed" style="animation-delay: 200ms">
        Not a school district site. Not a corporate template. A design system that says
        "career launchpad" — grounded, warm, and professional.
      </p>
    </div>
  </section>

  <!-- Brand Mark -->
  <section class="py-16 md:py-24 bg-brand-cream">
    <div class="max-w-[900px] mx-auto px-5 sm:px-8">
      <div class="on-scroll">
        <p class="text-[13px] font-semibold uppercase tracking-[0.2em] text-brand-copper mb-3">Brand Mark</p>
        <h2 class="font-[Schibsted_Grotesk] text-2xl md:text-4xl font-extrabold text-brand-navy tracking-tight">
          Typographic. Not a logo.
        </h2>
      </div>

      <div class="on-scroll mt-6 max-w-xl">
        <p class="text-brand-slate/60 leading-relaxed">
          Be Ready Beaumont doesn't need a logo — it needs a mark that's instantly legible,
          works at any size, and doesn't look like a school district seal. A typographic wordmark
          with a monogram anchor does that. It's confident without being corporate, distinctive
          without requiring a designer to maintain, and it scales from a favicon to a hallway banner.
        </p>
      </div>

      <!-- Dark background version -->
      <div class="on-scroll mt-12 bg-brand-dark rounded-2xl p-10 md:p-14 grain relative overflow-hidden">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-white/20 mb-8">On dark backgrounds</p>
        <div class="flex items-center gap-3">
          <div class="relative shrink-0">
            <div class="w-9 h-9 bg-brand-copper rounded-[6px] flex items-center justify-center font-[Outfit] font-semibold text-white text-[22px] leading-none rotate-[-2deg]">B!</div>
          </div>
          <div class="flex items-baseline gap-1"><span class="font-[Outfit] font-semibold text-[24px] leading-tight tracking-[-0.025em] text-white">Be Ready Beaumont</span><span class="text-brand-copper font-[Outfit] font-semibold text-[30px] inline-block rotate-[12deg] translate-y-[2px] ml-1">!</span>
        </div>
      </div>

      <!-- Light background version -->
      <div class="on-scroll mt-4 bg-white rounded-2xl p-10 md:p-14 border border-gray-200/60">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-slate/30 mb-8">On light backgrounds</p>
        <div class="flex items-center gap-3">
          <div class="relative shrink-0">
            <div class="w-9 h-9 bg-brand-copper rounded-[6px] flex items-center justify-center font-[Outfit] font-semibold text-white text-[22px] leading-none rotate-[-2deg]">B!</div>
          </div>
          <div class="flex items-baseline gap-1"><span class="font-[Outfit] font-semibold text-[24px] leading-tight tracking-[-0.025em] text-brand-navy">Be Ready Beaumont</span><span class="text-brand-copper font-[Outfit] font-semibold text-[30px] inline-block rotate-[12deg] translate-y-[2px] ml-1">!</span>
        </div>
      </div>

      <!-- Mark variations -->
      <div class="on-scroll mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- Full mark -->
        <div class="bg-white rounded-2xl p-6 border border-gray-200/60 text-center">
          <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-slate/30 mb-4">Full mark</p>
          <div class="flex items-center gap-2 justify-center">
            <div class="w-6 h-6 bg-brand-copper rounded-[5px] flex items-center justify-center font-[Outfit] font-semibold text-white text-[15px] leading-none rotate-[-2deg]">B!</div>
            <div class="font-[Outfit] font-semibold text-[15px] leading-tight tracking-[-0.025em] text-brand-navy text-left">Be Ready Beaumont</div><span class="text-brand-copper font-[Outfit] font-semibold text-[19px] inline-block rotate-[12deg] translate-y-[1px]">!</span>
          </div>
          <p class="text-[11px] text-brand-slate/40 mt-4">Navigation, headers, documents</p>
        </div>

        <!-- Monogram only -->
        <div class="bg-white rounded-2xl p-6 border border-gray-200/60 text-center">
          <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-slate/30 mb-4">Monogram</p>
          <div class="flex justify-center">
            <div class="w-12 h-12 bg-brand-copper rounded-[7px] flex items-center justify-center font-[Outfit] font-semibold text-white text-[28px] leading-none rotate-[-2deg]">B!</div>
          </div>
          <p class="text-[11px] text-brand-slate/40 mt-4">Favicons, social avatars, small spaces</p>
        </div>

        <!-- Wordmark only -->
        <div class="bg-white rounded-2xl p-6 border border-gray-200/60 text-center">
          <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-slate/30 mb-4">Wordmark only</p>
          <div class="flex items-center justify-center h-16">
            <div class="font-[Outfit] font-semibold text-[18px] tracking-[-0.025em] text-brand-navy">Be Ready Beaumont</div><span class="text-brand-copper font-[Outfit] font-semibold text-[22px] inline-block rotate-[12deg] translate-y-[1px]">!</span>
          </div>
          <p class="text-[11px] text-brand-slate/40 mt-4">Print materials, formal contexts</p>
        </div>
      </div>

      <!-- Construction notes -->
      <div class="on-scroll mt-4 bg-brand-copper/5 border border-brand-copper/10 rounded-2xl p-6">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-copper mb-3">Design rationale</p>
        <ul class="space-y-2 text-sm text-brand-slate/60">
          <li class="flex items-start gap-2">
            <span class="text-brand-copper mt-1 shrink-0">-</span>
            <span>The <strong class="text-brand-navy">2-degree rotation</strong> on the monogram breaks the rigidity of a square — it suggests forward motion without being whimsical.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-copper mt-1 shrink-0">-</span>
            <span>The <strong class="text-brand-navy">copper square</strong> is the only element that carries color — it anchors attention and works as a standalone mark at any size.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-copper mt-1 shrink-0">-</span>
            <span>The <strong class="text-brand-navy">tilted exclamation point</strong> turns "B" into "B!" — a generic letter becomes an ownable mark. It says "pay attention" and "this matters," which is exactly what the program needs to communicate to students who don't know it exists. The 12-degree tilt echoes the monogram's rotation while adding energy.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-copper mt-1 shrink-0">-</span>
            <span>On the <strong class="text-brand-navy">wordmark, the ! is copper</strong> — the only color in the mark. It overlaps slightly, breaking the baseline, making the name feel active rather than static. "Be Ready Beaumont" is a statement. The punctuation makes it one.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-copper mt-1 shrink-0">-</span>
            <span>The <strong class="text-brand-navy">wordmark uses Outfit</strong> (the body font) instead of the display font — it's warm and approachable, letting the monogram and the ! carry the visual weight.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-copper mt-1 shrink-0">-</span>
            <span><strong class="text-brand-navy">No "CTE Pathways" tagline.</strong> "CTE" is an insider acronym — it means nothing to parents, students, or community partners, which are three of your four audiences. "Be Ready Beaumont" already communicates purpose and place. A jargon subtitle underneath undermines that clarity and makes the mark feel institutional instead of aspirational.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-brand-copper mt-1 shrink-0">-</span>
            <span><strong class="text-brand-navy">No icon, no seal, no shield.</strong> Those are institutional signals. This mark says "program with momentum" — which is what Be Ready Beaumont actually is.</span>
          </li>
        </ul>
      </div>

      <!-- SVG downloads -->
      <div class="on-scroll mt-4 bg-white rounded-2xl p-6 border border-gray-200/60">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-slate/30 mb-4">Assets</p>
        <div class="flex flex-wrap gap-3">
          <a href={base("images/logos/brb-mark-dark.svg")} target="_blank" class="text-[13px] font-medium text-brand-copper hover:underline">brb-mark-dark.svg</a>
          <span class="text-brand-slate/20">|</span>
          <a href={base("images/logos/brb-mark-light.svg")} target="_blank" class="text-[13px] font-medium text-brand-copper hover:underline">brb-mark-light.svg</a>
          <span class="text-brand-slate/20">|</span>
          <a href={base("images/logos/brb-icon.svg")} target="_blank" class="text-[13px] font-medium text-brand-copper hover:underline">brb-icon.svg</a>
        </div>
      </div>
    </div>
  </section>

  <!-- What We're Not Building -->
  <section class="py-16 md:py-24 bg-brand-dark text-white grain relative overflow-hidden">
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-red/5 rounded-full blur-[120px]"></div>
    <div class="relative max-w-[900px] mx-auto px-5 sm:px-8">
      <div class="on-scroll">
        <p class="text-[13px] font-semibold uppercase tracking-[0.2em] text-brand-red/70 mb-3">Anti-patterns</p>
        <h2 class="font-[Schibsted_Grotesk] text-2xl md:text-4xl font-extrabold text-white tracking-tight">
          What we're not building.
        </h2>
        <p class="text-white/40 mt-3 max-w-xl leading-relaxed">
          Every CTE program in California has a web presence that looks like this.
          Buried in a district site, drowning in jargon, invisible to anyone who isn't
          already looking for it. Be Ready Beaumont deserves better.
        </p>
      </div>

      <!-- The SVUSD example -->
      <div class="on-scroll mt-10 bg-brand-steel/50 rounded-2xl p-6 md:p-8 border border-white/5">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-white/20 mb-4">Typical CTE program page</p>
        <div class="bg-white rounded-xl p-4 md:p-6 text-brand-slate">
          <!-- Fake district page -->
          <div class="flex items-center gap-3 border-b border-gray-200 pb-3 mb-4">
            <div class="w-8 h-8 bg-gray-200 rounded-full"></div>
            <div>
              <div class="text-[11px] font-bold text-gray-400">SADDLEBACK VALLEY USD</div>
              <div class="text-[9px] text-gray-300">Departments &gt; Educational Services &gt; College &amp; Career Readiness &gt; CTE</div>
            </div>
          </div>
          <div class="grid grid-cols-4 gap-4">
            <div class="col-span-1 space-y-1">
              <div class="text-[8px] font-bold text-gray-400 uppercase mb-2">Navigation</div>
              {["Home", "About Us", "Departments", "Educational Services", "College & Career", "CTE Programs", "Agriculture", "Computer Graphics", "Engineering", "Resources", "Contact"].map((item) => (
                <div class="text-[8px] text-gray-400 py-0.5 border-b border-gray-100">{item}</div>
              ))}
            </div>
            <div class="col-span-3">
              <div class="bg-gray-100 rounded h-20 mb-3 flex items-center justify-center text-[10px] text-gray-300">
                Stock landscape photo of local mountains
              </div>
              <div class="text-[10px] font-bold text-gray-500 mb-1">Career Technical Education (CTE)</div>
              <div class="space-y-1.5">
                <div class="h-2 bg-gray-100 rounded w-full"></div>
                <div class="h-2 bg-gray-100 rounded w-11/12"></div>
                <div class="h-2 bg-gray-100 rounded w-10/12"></div>
                <div class="h-2 bg-gray-100 rounded w-full"></div>
                <div class="h-2 bg-gray-100 rounded w-9/12"></div>
              </div>
              <div class="mt-3 text-[8px] text-gray-300">4,600+ students enrolled in CTE programs across 15 industry sectors...</div>
            </div>
          </div>
        </div>
        <p class="text-[12px] text-white/25 mt-3 text-center italic">
          Buried four levels deep in a district site. Sidebar navigation. Stock photography. Jargon headline.
        </p>
      </div>

      <!-- Anti-pattern list -->
      <div class="on-scroll mt-8 space-y-4">
        {[
          {
            dont: "Bury it in the district site",
            why: "If a partner, parent, or student has to click through Departments → Educational Services → College & Career Readiness → CTE to find you, they won't. A program this strong needs its own front door.",
          },
          {
            dont: "Lead with acronyms",
            why: "\"CTE\" means Career Technical Education to insiders and absolutely nothing to everyone else. \"Be Ready Beaumont\" tells you what it is. Lead with that.",
          },
          {
            dont: "Use a sidebar navigation",
            why: "Sidebars are for intranets and department portals. They signal \"this is a subsection of something bigger\" — the opposite of what you want when you're positioning a program as its own entity.",
          },
          {
            dont: "Stock photography",
            why: "You have students using angle grinders, running food trucks, and filming in broadcast studios. Stock photos of smiling teens with laptops actively demarket what you've built.",
          },
          {
            dont: "Academic voice",
            why: "\"The district shall implement systems of support to ensure...\" is how policies read, not how you recruit a 15-year-old. Speak like a career launchpad, not a compliance document.",
          },
          {
            dont: "Puzzle piece logos and clip art",
            why: "The default CTE visual language is puzzle pieces, gears, and graduation caps. These are generic symbols that could represent any program anywhere. They say nothing about what makes yours different.",
          },
          {
            dont: "PDF-only resources",
            why: "If your program overview is a downloadable PDF, it doesn't get indexed by search engines, doesn't render on mobile, can't be updated without a designer, and can't be tracked. Put it on the web.",
          },
        ].map((item) => (
          <div class="bg-brand-steel/30 rounded-xl p-5 border border-white/5">
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-brand-red/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-brand-red/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </div>
              <div>
                <p class="font-[Schibsted_Grotesk] font-bold text-white text-sm">Don't {item.dont.toLowerCase()}</p>
                <p class="text-[13px] text-white/35 mt-1 leading-relaxed">{item.why}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Typography -->
  <section class="py-16 md:py-24 bg-brand-cream">
    <div class="max-w-[900px] mx-auto px-5 sm:px-8">
      <div class="on-scroll">
        <p class="text-[13px] font-semibold uppercase tracking-[0.2em] text-brand-copper mb-3">Typography</p>
        <h2 class="font-[Schibsted_Grotesk] text-2xl md:text-4xl font-extrabold text-brand-navy tracking-tight">
          Two fonts. Clear hierarchy.
        </h2>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Display font -->
        <div class="on-scroll bg-white rounded-2xl p-8 border border-gray-200/60">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-copper bg-brand-copper/10 px-2.5 py-1 rounded-full">Display</span>
          </div>
          <p class="font-[Schibsted_Grotesk] text-5xl font-extrabold text-brand-navy leading-none tracking-tight">
            Schibsted Grotesk
          </p>
          <p class="text-sm text-brand-slate/50 mt-4 leading-relaxed">
            Headlines, stats, navigation. Sharp, editorial, confident — reads strong at large sizes
            without being theatrical.
          </p>
          <div class="mt-6 space-y-2 border-t border-gray-100 pt-6">
            <p class="font-[Schibsted_Grotesk] text-3xl font-extrabold text-brand-navy">Real Careers. — 800</p>
            <p class="font-[Schibsted_Grotesk] text-2xl font-bold text-brand-navy">Building & Construction — 700</p>
            <p class="font-[Schibsted_Grotesk] text-lg font-semibold text-brand-slate">Section Headings — 600</p>
            <p class="font-[Schibsted_Grotesk] text-base font-medium text-brand-slate/70">Navigation Labels — 500</p>
          </div>
        </div>

        <!-- Body font -->
        <div class="on-scroll bg-white rounded-2xl p-8 border border-gray-200/60">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-slate/40 bg-gray-100 px-2.5 py-1 rounded-full">Body</span>
          </div>
          <p class="font-[Outfit] text-5xl font-bold text-brand-navy leading-none">
            Outfit
          </p>
          <p class="text-sm text-brand-slate/50 mt-4 leading-relaxed">
            Body copy, descriptions, form labels. Geometric, friendly, excellent readability
            at small sizes. Pairs cleanly with Schibsted's editorial sharpness.
          </p>
          <div class="mt-6 space-y-2 border-t border-gray-100 pt-6">
            <p class="font-[Outfit] text-base font-normal text-brand-slate leading-relaxed">
              Be Ready Beaumont is Beaumont USD's K-12 Career Technical Education program,
              connecting students to real careers through 12 pathways across 7 industry sectors. — Regular 400
            </p>
            <p class="font-[Outfit] text-sm font-light text-brand-slate/60 leading-relaxed">
              Captions, metadata, and tertiary text use the light weight. — Light 300
            </p>
          </div>
        </div>
      </div>

      <!-- Type scale -->
      <div class="on-scroll mt-8 bg-white rounded-2xl p-8 border border-gray-200/60">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-slate/40 mb-6">Scale in action</p>
        <div class="space-y-4">
          <div class="flex items-baseline gap-4 border-b border-gray-50 pb-3">
            <span class="text-[11px] text-brand-slate/30 w-20 shrink-0 font-mono">5xl / 48</span>
            <p class="font-[Schibsted_Grotesk] text-5xl font-extrabold text-brand-navy tracking-tight leading-none">Real Careers.</p>
          </div>
          <div class="flex items-baseline gap-4 border-b border-gray-50 pb-3">
            <span class="text-[11px] text-brand-slate/30 w-20 shrink-0 font-mono">3xl / 30</span>
            <p class="font-[Schibsted_Grotesk] text-3xl font-extrabold text-brand-navy tracking-tight">Built for the Real World</p>
          </div>
          <div class="flex items-baseline gap-4 border-b border-gray-50 pb-3">
            <span class="text-[11px] text-brand-slate/30 w-20 shrink-0 font-mono">xl / 20</span>
            <p class="font-[Schibsted_Grotesk] text-xl font-bold text-brand-navy">I'm a Student</p>
          </div>
          <div class="flex items-baseline gap-4 border-b border-gray-50 pb-3">
            <span class="text-[11px] text-brand-slate/30 w-20 shrink-0 font-mono">base / 16</span>
            <p class="font-[Outfit] text-base text-brand-slate">Students building real skills for real careers — starting now.</p>
          </div>
          <div class="flex items-baseline gap-4">
            <span class="text-[11px] text-brand-slate/30 w-20 shrink-0 font-mono">xs / 12</span>
            <p class="text-xs uppercase tracking-[0.15em] font-semibold text-brand-copper">12 Career Pathways</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Color -->
  <section class="py-16 md:py-24 bg-brand-dark text-white grain relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-brand-copper/5 rounded-full blur-[120px]"></div>
    <div class="relative max-w-[900px] mx-auto px-5 sm:px-8">
      <div class="on-scroll">
        <p class="text-[13px] font-semibold uppercase tracking-[0.2em] text-brand-copper mb-3">Color</p>
        <h2 class="font-[Schibsted_Grotesk] text-2xl md:text-4xl font-extrabold text-white tracking-tight">
          Workshop tones. Warm copper accent.
        </h2>
        <p class="text-white/40 mt-3 max-w-xl leading-relaxed">
          Dark foundation with a warm, industrial palette. The copper carries every CTA, link,
          and highlight — it's the one color that says "act."
        </p>
      </div>

      <div class="mt-12 grid grid-cols-2 sm:grid-cols-5 gap-3">
        {colors.map((color) => (
          <div class="on-scroll group">
            <div
              class="aspect-square rounded-xl border border-white/10 mb-2 group-hover:scale-105 transition-transform duration-300"
              style={`background-color: ${color.hex}`}
            ></div>
            <p class="text-[12px] font-semibold text-white/70">{color.name}</p>
            <p class="text-[11px] text-white/25 font-mono">{color.hex}</p>
          </div>
        ))}
      </div>

      <!-- Usage -->
      <div class="on-scroll mt-12 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-brand-steel/50 rounded-xl p-6 border border-white/5">
          <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-copper mb-3">Dark mode (hero, nav, footer)</p>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-lg bg-brand-dark border border-white/10"></div>
            <div>
              <p class="text-white text-sm font-semibold">White text on dark</p>
              <p class="text-white/30 text-[12px]">Copper for links and accents</p>
            </div>
          </div>
        </div>
        <div class="bg-brand-cream rounded-xl p-6 border border-gray-200/60">
          <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-copper mb-3">Light mode (content sections)</p>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-lg bg-white border border-gray-200"></div>
            <div>
              <p class="text-brand-navy text-sm font-semibold">Navy text on cream</p>
