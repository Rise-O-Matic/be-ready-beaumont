---
import Base from '../layouts/Base.astro';
import { pathways } from '../content/pathways';
---

<Base title="For Students" description="Find out which CTE pathway fits your strengths, interests, and values.">
  <section class="bg-brand-navy text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-black">Your Future Starts Here</h1>
      <p class="mt-4 text-lg text-white/70 max-w-2xl">
        You don't have to wait until college to start building a career.
        CTE pathways give you real skills, real experience, and even college credit — right now.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-3xl font-black text-brand-navy">How It Works</h2>
          <div class="mt-8 space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand-blue rounded-full flex items-center justify-center text-white font-bold shrink-0">1</div>
              <div>
                <h3 class="font-bold text-brand-navy">Discover Your Strengths</h3>
                <p class="text-sm text-brand-slate/70 mt-1">Take the Holland's RIASEC assessment to understand what careers match your strengths, interests, and values. Not sure what you want to do? That's the point — we help you figure it out.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand-blue rounded-full flex items-center justify-center text-white font-bold shrink-0">2</div>
              <div>
                <h3 class="font-bold text-brand-navy">Choose a Pathway</h3>
                <p class="text-sm text-brand-slate/70 mt-1">Pick from 12 pathways across construction, culinary arts, digital media, healthcare, law enforcement, performing arts, and more. Each one is taught by someone who actually worked in the field.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand-blue rounded-full flex items-center justify-center text-white font-bold shrink-0">3</div>
              <div>
                <h3 class="font-bold text-brand-navy">Build Real Skills</h3>
                <p class="text-sm text-brand-slate/70 mt-1">Over 2-3 years, you'll earn industry certifications, college credit, and hands-on experience. Year 3 students work with community partners in real workplaces.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-brand-gold rounded-full flex items-center justify-center text-brand-navy font-bold shrink-0">4</div>
              <div>
                <h3 class="font-bold text-brand-navy">Graduate Ready</h3>
                <p class="text-sm text-brand-slate/70 mt-1">Walk across the stage with certifications, college credits, work experience, and a clear direction — whether that's college, apprenticeship, or straight into a career.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-brand-light rounded-2xl p-8">
          <h3 class="text-xl font-bold text-brand-navy mb-4">By the Numbers</h3>
          <div class="space-y-4">
            <div class="flex justify-between items-center border-b border-gray-200 pb-3">
              <span class="text-sm text-brand-slate/70">Students completing pathways</span>
              <span class="font-bold text-brand-navy text-lg">200+</span>
            </div>
            <div class="flex justify-between items-center border-b border-gray-200 pb-3">
              <span class="text-sm text-brand-slate/70">Pre-apprenticeship completions</span>
              <span class="font-bold text-brand-navy text-lg">46</span>
            </div>
            <div class="flex justify-between items-center border-b border-gray-200 pb-3">
              <span class="text-sm text-brand-slate/70">Students in college-level coursework</span>
              <span class="font-bold text-brand-navy text-lg">571</span>
            </div>
            <div class="flex justify-between items-center border-b border-gray-200 pb-3">
              <span class="text-sm text-brand-slate/70">Fusion 360 exam pass rate</span>
              <span class="font-bold text-brand-navy text-lg">96%</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-brand-slate/70">Work-based learning placements</span>
              <span class="font-bold text-brand-navy text-lg">23</span>
            </div>
          </div>

          <div class="mt-8 p-4 bg-brand-blue/10 rounded-xl">
            <p class="text-sm font-semibold text-brand-blue">Explore your interests</p>
            <p class="text-xs text-brand-slate/60 mt-1">Use Pathful to take career assessments and discover pathways that match you.</p>
            <a
              href="https://www.pathful.com"
              target="_blank"
              rel="noopener"
              class="mt-3 inline-flex items-center gap-1 text-sm font-bold text-brand-blue hover:underline"
            >
              Go to Pathful
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pathway Quick Links -->
  <section class="py-16 md:py-24 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-black text-brand-navy mb-8">Pick Your Pathway</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {pathways.map((p) => (
          <a
            href={`/pathways/${p.slug}`}
            class="flex items-center gap-3 bg-white rounded-lg p-4 shadow-sm border border-gray-100 hover:shadow-md hover:border-brand-blue/20 transition-all group"
          >
            <img src={p.photo} alt={p.name} class="w-14 h-14 rounded-lg object-cover shrink-0" loading="lazy" />
            <div>
              <p class="font-bold text-brand-navy text-sm group-hover:text-brand-blue transition-colors">{p.name}</p>
              <p class="text-xs text-brand-slate/50">{p.school}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
