---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Get in touch with Be Ready Beaumont CTE Pathways.">
  <section class="bg-brand-navy text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-black">Get in Touch</h1>
      <p class="mt-4 text-lg text-white/70 max-w-2xl">
        Whether you're a student, parent, or potential partner — we'd love to hear from you.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-black text-brand-navy mb-6">Send Us a Message</h2>
          <form class="space-y-4" name="contact" method="POST" data-netlify="true">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="first-name" class="block text-sm font-medium text-brand-navy mb-1">First Name</label>
                <input type="text" id="first-name" name="first-name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-blue focus:border-brand-blue" />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-medium text-brand-navy mb-1">Last Name</label>
                <input type="text" id="last-name" name="last-name" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-blue focus:border-brand-blue" />
              </div>
            </div>
            <div>
              <label for="contact-email" class="block text-sm font-medium text-brand-navy mb-1">Email</label>
              <input type="email" id="contact-email" name="email" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-blue focus:border-brand-blue" />
            </div>
            <div>
              <label for="contact-role" class="block text-sm font-medium text-brand-navy mb-1">I am a...</label>
              <select id="contact-role" name="role" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-blue focus:border-brand-blue bg-white">
                <option value="">Select one...</option>
                <option>Student</option>
                <option>Parent / Guardian</option>
                <option>Community Partner / Business</option>
                <option>Educator</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label for="contact-message" class="block text-sm font-medium text-brand-navy mb-1">Message</label>
              <textarea id="contact-message" name="message" rows="4" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-brand-blue focus:border-brand-blue"></textarea>
            </div>
            <button type="submit" class="w-full px-4 py-2.5 text-sm font-bold bg-brand-gold text-brand-navy rounded-lg hover:bg-amber-400 transition-colors">
              Send Message
            </button>
          </form>
        </div>

        <div class="space-y-8">
          <div>
            <h3 class="text-lg font-bold text-brand-navy mb-4">Direct Contacts</h3>
            <div class="space-y-4">
              {[
                {
                  name: "Dr. Michael Breyer",
                  title: "Director, College & Career Readiness",
                  email: "mbreyer@beaumontusd.k12.ca.us",
                  note: "Program leadership, strategic partnerships",
                },
                {
                  name: "Alicia Chamberlain",
                  title: "TOSA, College & Career Readiness",
                  email: "achamberlain@beaumontusd.k12.ca.us",
                  note: "Program information, curriculum questions",
                },
                {
                  name: "Susan Aguilar-Martinez",
                  title: "Career Readiness Coordinator",
                  email: "saguilarMartinez@beaumontusd.k12.ca.us",
                  note: "Work-based learning, community partnerships",
                },
              ].map((contact) => (
                <div class="bg-brand-light rounded-xl p-5">
                  <p class="font-bold text-brand-navy">{contact.name}</p>
                  <p class="text-sm text-brand-slate/60">{contact.title}</p>
                  <a href={`mailto:${contact.email}`} class="text-sm text-brand-blue hover:underline mt-1 inline-block">
                    {contact.email}
                  </a>
                  <p class="text-xs text-brand-slate/40 mt-1">{contact.note}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-brand-navy rounded-2xl p-6 text-white">
            <h3 class="font-bold text-lg mb-2">Beaumont Unified School District</h3>
            <p class="text-sm text-white/70">
              350 E. Sixth Street<br />
              Beaumont, CA 92223
            </p>
            <a
              href="https://www.beaumontusd.k12.ca.us"
              target="_blank"
              rel="noopener"
              class="text-sm text-brand-gold hover:underline mt-3 inline-block"
            >
              beaumontusd.k12.ca.us
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
