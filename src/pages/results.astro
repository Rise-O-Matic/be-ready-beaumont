---
import { base } from '../utils/base';
import Base from '../layouts/Base.astro';
import StatBar from '../components/StatBar.astro';
---

<Base title="Results" description="Be Ready Beaumont CTE program outcomes, metrics, and success stories.">
  <section class="bg-brand-navy text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-black">Results</h1>
      <p class="mt-4 text-lg text-white/70 max-w-2xl">
        The numbers tell the story. Be Ready Beaumont is growing, and students are graduating
        with real skills, certifications, and experience.
      </p>
    </div>
  </section>

  <StatBar />

  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Growth -->
        <div>
          <h2 class="text-2xl font-black text-brand-navy mb-6">Pathway Completers — Year Over Year</h2>
          <div class="space-y-3">
            {[
              { year: "2020-21", count: 119, pct: 36 },
              { year: "2021-22", count: 127, pct: 39 },
              { year: "2022-23", count: 144, pct: 44 },
              { year: "2023-24", count: 167, pct: 51 },
              { year: "2024-25", count: 200, pct: 61, projected: true },
            ].map((row) => (
              <div>
                <div class="flex justify-between text-sm mb-1">
                  <span class="font-medium text-brand-navy">{row.year} {row.projected ? '(projected)' : ''}</span>
                  <span class="font-bold text-brand-navy">{row.count}{row.projected ? '+' : ''}</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-3">
                  <div
                    class="bg-brand-blue rounded-full h-3 transition-all"
                    style={`width: ${row.pct}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
          <p class="text-xs text-brand-slate/50 mt-4">68% growth in pathway completers over 4 years</p>
        </div>

        <!-- Key Metrics -->
        <div>
          <h2 class="text-2xl font-black text-brand-navy mb-6">2024-25 Snapshot</h2>
          <div class="grid grid-cols-2 gap-4">
            {[
              { value: "571", label: "Students in college-level CTE coursework" },
              { value: "496", label: "Middle school students in CTE programs" },
              { value: "46", label: "Pre-apprenticeship completions" },
              { value: "23", label: "Off-site work-based learning placements" },
              { value: "96%", label: "Fusion 360 industry exam pass rate" },
              { value: "30+", label: "Community partner organizations" },
            ].map((stat) => (
              <div class="bg-brand-light rounded-xl p-5">
                <div class="text-2xl font-black text-brand-blue">{stat.value}</div>
                <div class="text-xs text-brand-slate/60 mt-1">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Grant Funding -->
  <section class="py-16 md:py-24 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-black text-brand-navy mb-6">Grant Investment</h2>
      <p class="text-brand-slate/70 mb-8 max-w-2xl">
        Since 2016-17, Be Ready Beaumont has been awarded $11.6 million in grants to create,
        expand, and sustain CTE pathways aligned with industry trends.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { name: "CTE Incentive Grant", desc: "State funding for CTE pathway development and expansion" },
          { name: "Perkins V", desc: "Federal funding for career and technical education programs" },
          { name: "K-12 Strong Workforce Program", desc: "Funding to expand middle school medical programs ($365K in 2025)" },
          { name: "Golden State Pathways Program", desc: "Planning grant for Education & Family Services pathway ($121K)" },
        ].map((grant) => (
          <div class="bg-white rounded-xl p-6 border border-gray-200">
            <h3 class="font-bold text-brand-navy">{grant.name}</h3>
            <p class="text-sm text-brand-slate/70 mt-1">{grant.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stories -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-black text-brand-navy mb-8">Success Stories</h2>

      <div class="space-y-8">
        <div class="bg-brand-light rounded-2xl p-8">
          <div class="inline-flex items-center gap-2 bg-brand-gold/20 text-brand-gold px-3 py-1 rounded-full text-xs font-semibold mb-4">
            Golden Bell Award Highlight
          </div>
          <h3 class="text-xl font-bold text-brand-navy">Breaking Barriers in the Kitchen</h3>
          <p class="mt-3 text-brand-slate/80 leading-relaxed">
            A visually impaired student enrolled in the highly competitive Culinary Arts pathway.
            Despite initial concerns about safety in a fast-paced industrial kitchen, the CTE and
            Special Education departments collaborated to make it work — braille labels on equipment,
            adapted materials, and a team of peers who planned and problem-solved together.
          </p>
          <p class="mt-3 text-brand-slate/80 leading-relaxed">
            The student completed Year 1 and is continuing to the capstone course. The lessons learned
            — perseverance, teamwork, adaptability — transcended culinary arts entirely.
          </p>
        </div>

        <div class="bg-brand-light rounded-2xl p-8">
          <h3 class="text-xl font-bold text-brand-navy">Student-Run Food Truck</h3>
          <p class="mt-3 text-brand-slate/80 leading-relaxed">
            The Culinary Arts pathway expanded to include a mobile kitchen — a fully operational food
            trailer run entirely by students. Advanced students manage menu planning, food costing,
            catering logistics, and customer service. It's not a simulation — it's a real business
            operated by high schoolers.
          </p>
        </div>

        <div class="bg-brand-light rounded-2xl p-8">
          <h3 class="text-xl font-bold text-brand-navy">STAAC Program</h3>
          <p class="mt-3 text-brand-slate/80 leading-relaxed">
            The Skills to Transition Appropriately and Confidently (STAAC) Program is a summer
            initiative that exposes students with special needs to CTE pathways and career skills.
            It's a direct example of how Be Ready Beaumont extends opportunity to every student,
            not just the ones who fit neatly into traditional programs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Recognition -->
  <section class="py-16 md:py-24 bg-brand-navy text-white text-center">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-flex items-center gap-2 bg-brand-gold/20 text-brand-gold px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        CSBA Golden Bell Award 2024
      </div>
      <p class="text-xl md:text-2xl font-medium leading-relaxed text-white/90">
        The California School Boards Association recognized Be Ready Beaumont as one of the
        best CTE programs in California — from a record number of applications.
      </p>
    </div>
  </section>
</Base>
