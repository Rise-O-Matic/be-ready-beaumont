---
import Proposal from '../layouts/Proposal.astro';
import { base } from '../utils/base';

// Dynamic dates based on a hypothetical signing date
const signingDate = new Date('2026-04-07');
const sprint1Start = new Date(signingDate);
const sprint1End = new Date(signingDate); sprint1End.setDate(sprint1End.getDate() + 27);
const sprint2Start = new Date(sprint1End); sprint2Start.setDate(sprint2Start.getDate() + 1);
const sprint2End = new Date(sprint2Start); sprint2End.setDate(sprint2End.getDate() + 27);
const sprint3Start = new Date(sprint2End); sprint3Start.setDate(sprint3Start.getDate() + 1);
const sprint3End = new Date(sprint3Start); sprint3End.setDate(sprint3End.getDate() + 27);

function fmt(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<Proposal title="The Plan" current="plan">
  <!-- Hero -->
  <section class="relative bg-brand-dark text-white py-20 md:py-28 overflow-hidden grain">
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-copper/5 rounded-full blur-[120px]"></div>
    <div class="relative max-w-[900px] mx-auto px-5 sm:px-8">
      <p class="reveal text-[13px] font-semibold uppercase tracking-[0.2em] text-brand-copper mb-4">Step 2 of 4</p>
      <h1 class="reveal font-[Schibsted_Grotesk] text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.05]" style="animation-delay: 100ms">
        Ship first.<br />
        <span class="text-brand-copper">Refine later.</span>
      </h1>
      <p class="reveal text-lg md:text-xl text-white/50 mt-6 max-w-xl leading-relaxed" style="animation-delay: 200ms">
        Three sprints. 12 weeks. You have a URL, a pitch kit, and recruitment materials
        in hand — not a strategy deck that sits in a drawer.
      </p>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 md:py-24 bg-brand-cream">
    <div class="max-w-[900px] mx-auto px-5 sm:px-8">
      <!-- Sprint 1 -->
      <div class="on-scroll relative pl-8 md:pl-12 pb-16 border-l-2 border-brand-copper/20">
        <div class="absolute left-[-9px] top-0 w-4 h-4 bg-brand-copper rounded-full border-4 border-brand-cream"></div>
        <div class="mb-2 flex items-center gap-3">
          <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-copper bg-brand-copper/10 px-2.5 py-1 rounded-full">Sprint 1</span>
          <span class="text-[12px] text-brand-slate/40">{fmt(sprint1Start)} — {fmt(sprint1End)}</span>
        </div>
        <h3 class="font-[Schibsted_Grotesk] text-2xl md:text-3xl font-extrabold text-brand-navy tracking-tight mt-3">Ship It</h3>
        <p class="text-brand-slate/60 mt-2 leading-relaxed max-w-xl">
          Build the website and partner pitch kit simultaneously. The content corpus is already
          extracted — we populate, design, and launch without a discovery phase.
        </p>

        <div class="mt-6 space-y-3">
          <div class="bg-white rounded-xl p-5 border border-gray-200/60">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-[Schibsted_Grotesk] font-bold text-brand-navy">Website</p>
                <p class="text-sm text-brand-slate/60 mt-1">12 pathway pages, audience sections, partner inquiry form, analytics. Static site on free hosting — zero maintenance.</p>
              </div>
              <span class="text-sm font-[Schibsted_Grotesk] font-bold text-brand-copper whitespace-nowrap">$3,500–5,000</span>
            </div>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-200/60">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-[Schibsted_Grotesk] font-bold text-brand-navy">Community Partner Pitch Kit</p>
                <p class="text-sm text-brand-slate/60 mt-1">Print + digital leave-behind for partner meetings. Something to put in their hands.</p>
              </div>
              <span class="text-sm font-[Schibsted_Grotesk] font-bold text-brand-copper whitespace-nowrap">$1,500</span>
            </div>
          </div>
        </div>
        <div class="mt-4 bg-brand-copper/5 border border-brand-copper/10 rounded-xl p-4">
          <p class="text-sm text-brand-slate/70">
            <span class="font-semibold text-brand-navy">What you get:</span> Michael has a URL to share and a PDF to hand someone at a meeting. The two most urgent problems solved in 4 weeks.
          </p>
        </div>
      </div>

      <!-- Sprint 2 -->
      <div class="on-scroll relative pl-8 md:pl-12 pb-16 border-l-2 border-brand-copper/20">
        <div class="absolute left-[-9px] top-0 w-4 h-4 bg-white border-2 border-brand-copper/40 rounded-full"></div>
        <div class="mb-2 flex items-center gap-3">
          <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-slate/40 bg-gray-100 px-2.5 py-1 rounded-full">Sprint 2</span>
          <span class="text-[12px] text-brand-slate/40">{fmt(sprint2Start)} — {fmt(sprint2End)}</span>
        </div>
        <h3 class="font-[Schibsted_Grotesk] text-2xl md:text-3xl font-extrabold text-brand-navy tracking-tight mt-3">Fill the Halls</h3>
        <p class="text-brand-slate/60 mt-2 leading-relaxed max-w-xl">
          The hub exists. Now create the spokes — materials that drive students, parents,
          and partners to the website.
        </p>

        <div class="mt-6 space-y-3">
          <div class="bg-white rounded-xl p-5 border border-gray-200/60">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-[Schibsted_Grotesk] font-bold text-brand-navy">Student Recruitment Package</p>
                <p class="text-sm text-brand-slate/60 mt-1">Hallway posters, digital signage, social graphics. Designed to interrupt, not inform — QR codes drive to the website.</p>
              </div>
              <span class="text-sm font-[Schibsted_Grotesk] font-bold text-brand-copper whitespace-nowrap">$1,700</span>
            </div>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-200/60">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-[Schibsted_Grotesk] font-bold text-brand-navy">Pathway One-Sheets (6 pathways)</p>
                <p class="text-sm text-brand-slate/60 mt-1">Individual fact sheets for the 6 strongest pathways. Print + digital, each links back to the website.</p>
              </div>
              <span class="text-sm font-[Schibsted_Grotesk] font-bold text-brand-copper whitespace-nowrap">$1,700</span>
            </div>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-200/60">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-[Schibsted_Grotesk] font-bold text-brand-navy">Social Content Templates</p>
                <p class="text-sm text-brand-slate/60 mt-1">10 branded templates (Instagram, Facebook) staff can populate without a designer.</p>
              </div>
              <span class="text-sm font-[Schibsted_Grotesk] font-bold text-brand-copper whitespace-nowrap">$800</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Sprint 3 -->
      <div class="on-scroll relative pl-8 md:pl-12 pb-4 border-l-2 border-transparent">
        <div class="absolute left-[-9px] top-0 w-4 h-4 bg-white border-2 border-gray-200 rounded-full"></div>
        <div class="mb-2 flex items-center gap-3">
          <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-brand-slate/40 bg-gray-100 px-2.5 py-1 rounded-full">Sprint 3</span>
          <span class="text-[12px] text-brand-slate/40">{fmt(sprint3Start)} — {fmt(sprint3End)}</span>
        </div>
        <h3 class="font-[Schibsted_Grotesk] text-2xl md:text-3xl font-extrabold text-brand-navy tracking-tight mt-3">Refine & Expand</h3>
        <p class="text-brand-slate/60 mt-2 leading-relaxed max-w-xl">
          By now the website has traffic data and materials are in use. Formalize the visual
          identity, complete the one-sheet set, and build the parent package.
        </p>

        <div class="mt-6 space-y-3">
          <div class="bg-white rounded-xl p-5 border border-gray-200/60">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-[Schibsted_Grotesk] font-bold text-brand-navy">Parent Information Package</p>
                <p class="text-sm text-brand-slate/60 mt-1">"Why should my kid do this?" — answered with outcomes, certifications, and career paths.</p>
              </div>
              <span class="text-sm font-[Schibsted_Grotesk] font-bold text-brand-copper whitespace-nowrap">$1,000</span>
            </div>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-200/60">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-[Schibsted_Grotesk] font-bold text-brand-navy">Visual Identity Refinement</p>
                <p class="text-sm text-brand-slate/60 mt-1">Lock in the brand that emerged from Sprint 1-2. Colors, typography, logo usage guidelines.</p>
              </div>
              <span class="text-sm font-[Schibsted_Grotesk] font-bold text-brand-copper whitespace-nowrap">$1,000–1,500</span>
            </div>
          </div>
          <div class="bg-white rounded-xl p-5 border border-gray-200/60">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-[Schibsted_Grotesk] font-bold text-brand-navy">Remaining Pathway One-Sheets (6)</p>
                <p class="text-sm text-brand-slate/60 mt-1">Complete the set for all 12 pathways.</p>
              </div>
              <span class="text-sm font-[Schibsted_Grotesk] font-bold text-brand-copper whitespace-nowrap">$1,000</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-brand-cream">
    <div class="max-w-[900px] mx-auto px-5 sm:px-8 text-center on-scroll">
      <p class="text-brand-slate/40 text-sm mb-3">Want to see what the website actually looks like? We already built it.</p>
      <a
        href={base("prototype")}
        class="group inline-flex items-center gap-3 px-8 py-4 text-sm font-semibold uppercase tracking-wider bg-brand-copper text-white rounded-lg hover:bg-brand-copper/90 transition-all duration-300 hover:translate-y-[-2px] hover:shadow-xl hover:shadow-brand-copper/25"
      >
        See the Prototype
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Proposal>
