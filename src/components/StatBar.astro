---
const stats = [
  { value: "12", label: "CTE Pathways" },
  { value: "7", label: "Industry Sectors" },
  { value: "200+", label: "Pathway Completers" },
  { value: "96%", label: "Fusion 360 Pass Rate" },
];
---

<section class="relative bg-brand-navy border-y border-white/5 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-brand-copper/5 via-transparent to-brand-copper/5"></div>
  <div class="relative max-w-[1400px] mx-auto px-5 sm:px-8 lg:px-12 py-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      {stats.map((stat, i) => (
        <div class="text-center md:text-left reveal" style={`animation-delay: ${i * 100 + 100}ms`}>
          <div class="text-3xl md:text-4xl font-[Syne] font-extrabold text-brand-copper leading-none">{stat.value}</div>
          <div class="text-[13px] text-white/35 mt-1.5 uppercase tracking-[0.15em] font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
