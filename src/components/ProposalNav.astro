---
import { base } from '../utils/base';

interface Props {
  current: 'audit' | 'plan' | 'style-guide' | 'prototype' | 'estimate';
}

const { current } = Astro.props;

const steps = [
  { id: 'audit', label: 'Challenge', href: base('audit') },
  { id: 'plan', label: 'Plan', href: base('plan') },
  { id: 'style-guide', label: 'Style', href: base('style-guide') },
  { id: 'prototype', label: 'Prototype', href: base('prototype') },
  { id: 'estimate', label: 'Estimate', href: base('estimate') },
];

const currentIndex = steps.findIndex(s => s.id === current);
---

<nav class="fixed top-0 left-0 right-0 z-[60] bg-brand-dark/98 backdrop-blur-md border-b border-white/5">
  <div class="max-w-[1400px] mx-auto px-5 sm:px-8">
    <div class="flex items-center justify-between h-11">
      <!-- Beadloom mark -->
      <div class="flex items-center gap-2">
        <span class="text-[11px] uppercase tracking-[0.2em] text-white/25 font-medium">Proposal</span>
        <span class="text-[11px] text-white/10">|</span>
        <span class="text-[11px] text-white/30">Be Ready Beaumont</span>
      </div>

      <!-- Steps -->
      <div class="flex items-center gap-1">
        {steps.map((step, i) => {
          const isActive = step.id === current;
          const isPast = i < currentIndex;
          return (
            <a
              href={step.href}
              class:list={[
                "flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-medium uppercase tracking-[0.08em] transition-all duration-300",
                isActive && "bg-brand-copper/20 text-brand-copper",
                isPast && "text-white/40 hover:text-white/60",
                !isActive && !isPast && "text-white/20 hover:text-white/40",
              ]}
            >
              <span class:list={[
                "w-4 h-4 rounded-full flex items-center justify-center text-[9px] font-bold border transition-colors",
                isActive && "bg-brand-copper border-brand-copper text-white",
                isPast && "bg-white/10 border-white/20 text-white/50",
                !isActive && !isPast && "border-white/10 text-white/15",
              ]}>
                {isPast ? (
                  <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                ) : (
                  <span>{i + 1}</span>
                )}
              </span>
              <span class="hidden sm:inline">{step.label}</span>
            </a>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Progress bar -->
  <div class="h-px bg-white/5">
    <div
      class="h-full bg-brand-copper transition-all duration-500"
      style={`width: ${((currentIndex + 1) / steps.length) * 100}%`}
    ></div>
  </div>
</nav>
