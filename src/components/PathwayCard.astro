---
interface Props {
  slug: string;
  name: string;
  sector: string;
  photo: string;
  description: string;
}

const { slug, name, sector, photo, description } = Astro.props;
---

<a
  href={`/pathways/${slug}`}
  class="group block bg-brand-steel/50 rounded-2xl overflow-hidden border border-white/5 hover:border-brand-copper/30 transition-all duration-500 hover:shadow-2xl hover:shadow-brand-copper/10 hover:-translate-y-1"
>
  <div class="aspect-[16/10] overflow-hidden relative">
    <img
      src={photo}
      alt={name}
      class="w-full h-full object-cover img-duotone group-hover:scale-105 transition-all duration-700"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/80 via-transparent to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-5">
      <p class="text-[11px] font-semibold uppercase tracking-[0.15em] text-brand-copper">{sector}</p>
      <h3 class="text-lg font-[Syne] font-bold text-white mt-1 group-hover:text-brand-copper transition-colors duration-300">{name}</h3>
    </div>
  </div>
  <div class="p-5 pt-3">
    <p class="text-sm text-white/40 line-clamp-2 leading-relaxed">{description}</p>
    <div class="mt-4 flex items-center gap-1 text-[13px] font-semibold text-brand-copper group-hover:gap-2 transition-all duration-300">
      <span>Explore</span>
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</a>
